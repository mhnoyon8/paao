# Server
PORT=8080
NODE_ENV=development

# Client
VITE_API_URL=http://localhost:8080
VITE_SOCKET_URL=http://localhost:8080

# Database
DB_PATH=./server/db/paao.sqlite

# Optional: OpenClaw Integration
OPENCLAW_API_KEY=
OPENCLAW_AGENT_IDS=
OPENCLAW_GATEWAY_URL=ws://127.0.0.1:18789
OPENCLAW_GATEWAY_TOKEN=

# Multi-user auth (basic)
AUTH_REQUIRED=false
AUTH_JWT_SECRET=change-me-in-production
AUTH_USERS_JSON={"admin":"admin123"}

# Workflow cleanup
WORKFLOW_RETENTION_DAYS=30
WORKFLOW_CLEANUP_INTERVAL_MS=3600000

# Optional: Telegram Integration (phase-1)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_TOPICS_JSON={"aether":123,"orion":124}
